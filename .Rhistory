# 1.2
# extreiem la matriu
X <- assay(se_subset)
# anàlisis valors faltants:
na_prop <- rowMeans(is.na(X)) # percentage de NA
na_prop
X_filtered <- X[na_prop <= 0.2, ] # eliminar >20%
# knn
library(impute)
X_imputed <- impute.knn(X_filtered)$data
# normalitzacio de dades
X_log <- log2(X_imputed + 1)
# centrar i escalar
X_scaled <- scale(X_log)
X_final <- X_scaled
# 1.3 PCA
pca <- prcomp(t(X_final), scale. = FALSE)
# variança
summary(pca)
var_explained <- pca$sdev^2 / sum(pca$sdev^2)
var_explained
# gràfic
plot(pca$x[,1], pca$x[,2],
xlab = "PC1",
ylab = "PC2",
pch = 19)
group <- colData(se_subset)$group
plot(pca$x[,1], pca$x[,2],
col = ifelse(group == "Case", "red", "blue"),
pch = 19,
xlab = "PC1",
ylab = "PC2")
group <- colData(se_subset)$group
plot(pca$x[,1], pca$x[,2],
col = ifelse(group == "Case", "red", "blue"),
pch = 19,
xlab = "PC1",
ylab = "PC2")
legend("topright",
legend = c("Case", "Control"),
col = c("red", "blue"),
pch = 19)
legend("center",
legend = c("Case", "Control"),
col = c("red", "blue"),
pch = 19)
group <- colData(se_subset)$group
plot(pca$x[,1], pca$x[,2],
col = ifelse(group == "Case", "red", "blue"),
pch = 19,
xlab = "PC1",
ylab = "PC2")
legend("center",
legend = c("Case", "Control"),
col = c("red", "blue"),
pch = 19)
