library(readxl)
library(ggplot2)
library(factoextra)
# PCA
# Paquets necessaris
library(readxl)
# llegir dades AT+EVs
data <- readxl::read_excel("ATEVsn_resultados_proteómica_final.xlsx", sheet = "Proteins")
str(data)
head(data)
# 2. Selecciona només les columnes de mostres
mostres <- dades[, grep("^Sample", colnames(dades))]
# 2. Selecciona només les columnes de mostres
mostres <- data[, grep("^Sample", colnames(dades))]
# 3. Converteix a numeric
mostres <- as.data.frame(lapply(mostres, function(x) as.numeric(gsub(",", ".", x))))
# 2. Selecciona només les columnes de mostres
mostres <- data[, grep("^Sample", colnames(dades))]
# 2. Selecciona només les columnes de mostres
mostres <- data[, grep("^Sample", colnames(data))]
# 3. Converteix a numeric
mostres <- as.data.frame(lapply(mostres, function(x) as.numeric(gsub(",", ".", x))))
# 4. Log-transformació
mostres_log <- log2(mostres + 1)
# 5. PCA
# Transposem perquè les mostres han de ser files
pca <- prcomp(t(mostres_log), center = TRUE, scale. = TRUE)
# 5. PCA
# Transposem perquè les mostres han de ser files
mostres_t <- t(mostres_log)
# Filtrar columnes (proteïnes) amb variància > 0
mostres_t <- mostres_t[, apply(mostres_t, 2, var) > 0]
# PCA
pca <- prcomp(mostres_t, center = TRUE, scale. = TRUE)
# PCA
pca <- prcomp(mostres_t, center = TRUE, scale. = FALSE)
# 6. Extraiem les coordenades dels dos primers components
scores <- pca$x[, 1:2]
# 7. Plot bàsic
plot(scores,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica",
pch = 19, col = "steelblue")
text(scores, labels = colnames(mostres), pos = 3, cex = 0.7)
summary(pca)
plot(pca$x[,1], pca$x[,2], xlab="PC1", ylab="PC2", pch=19, col="steelblue")
text(pca$x[,1], pca$x[,2], labels=colnames(mostres), pos=3, cex=0.7)
pca$rotation[,1:2]
dist_mat <- dist(t(mostres_log))
hc <- hclust(dist_mat)
plot(hc, labels = colnames(mostres))
getwd()
# PCA
# Paquets necessaris
library(readxl)
# llegir dades AT+EVs
data <- readxl::read_excel("ATEVsn_resultados_proteómica_final.xlsx", sheet = "Proteins")
str(data)
head(data)
mostres <- data[, grep("^Sample", colnames(data))]
mostres <- as.data.frame(lapply(mostres, function(x) as.numeric(gsub(",", ".", x))))
mostres_log <- log2(mostres + 1)
# 2. PCA sense escalar (scale=FALSE)
mostres_t <- t(mostres_log)
pca <- prcomp(mostres_t, center = TRUE, scale. = FALSE)
mostres <- data[, grep("^Sample", colnames(data))]
mostres <- as.data.frame(lapply(mostres, function(x) as.numeric(gsub(",", ".", x))))
mostres_log <- log2(mostres + 1)
# 2. PCA sense escalar (scale=FALSE)
mostres_t <- t(mostres_log)
pca <- prcomp(mostres_t, center = TRUE, scale. = FALSE)
# Comptar valors no NA per proteïna
mostres_log <- mostres_log[rowSums(is.na(mostres_log)) < 0.5*ncol(mostres_log), ]
# 2. PCA sense escalar (scale=FALSE)
mostres_t <- t(mostres_log)
pca <- prcomp(mostres_t, center = TRUE, scale. = FALSE)
sum(is.na(mostres_log))
# Comptar valors no NA per proteïna
mostres_log <- mostres_log[rowSums(is.na(mostres_log)) < 0.5*ncol(mostres_log), ]
sum(is.na(mostres_log))
mostres_log <- log2(mostres + 1)
# Comptar valors no NA per proteïna
mostres_log[is.na(mostres_log)] <- 0
mostres_log[is.infinite(mostres_log)] <- 0
mostres_log[is.infinite(mostres_log)] <- 0
sum(is.na(mostres_log))
# 2. PCA sense escalar (scale=FALSE)
mostres_t <- t(mostres_log)
pca <- prcomp(mostres_t, center = TRUE, scale. = FALSE)
summary(pca)
# 3. Definim clusters manualment (pots fer clustering amb k-means si vols)
# Exemple: fem 4 clusters amb k-means
set.seed(123)
km <- kmeans(pca$x[,1:2], centers = 4)
clusters <- km$cluster
# 4. Plot PCA amb colors per cluster
plot(pca$x[,1], pca$x[,2],
col = clusters, pch = 19,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica amb 4 clusters")
text(pca$x[,1], pca$x[,2], labels = colnames(mostres), pos = 3, cex = 0.7)
var_prot <- apply(mostres_log, 1, var)       # variància per proteïna
mostres_top <- mostres_log[var_prot > quantile(var_prot, 0.75), ]  # top 25% més variable
pca_top <- prcomp(t(mostres_top), center=TRUE, scale.=FALSE)
# 4. Plot PCA amb colors per cluster
plot(pca_top$x[,1], pca$x[,2],
col = clusters, pch = 19,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica amb 4 clusters")
# 4. Plot PCA amb colors per cluster
plot(pca$x[,1], pca$x[,2],
col = clusters, pch = 19,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica amb 4 clusters")
mostres_z <- t(scale(t(mostres_log)))
pca <- prcomp(mostres_z, center = TRUE, scale. = FALSE)
# 4. Plot PCA amb colors per cluster
plot(pca$x[,1], pca$x[,2],
col = clusters, pch = 19,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica amb 4 clusters")
t
# 4. Plot PCA amb colors per cluster
plot(pca$x[,1], pca$x[,2],
col = clusters, pch = 19,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica amb 4 clusters")
# 2. PCA sense escalar (scale=FALSE)
mostres_t <- t(mostres_log)
pca <- prcomp(mostres_t, center = TRUE, scale. = FALSE)
# 4. Plot PCA amb colors per cluster
plot(pca$x[,1], pca$x[,2],
col = clusters, pch = 19,
xlab = paste0("PC1 (", round(summary(pca)$importance[2,1]*100,1), "%)"),
ylab = paste0("PC2 (", round(summary(pca)$importance[2,2]*100,1), "%)"),
main = "PCA Proteòmica amb 4 clusters")
text(pca$x[,1], pca$x[,2], labels = colnames(mostres), pos = 3, cex = 0.7)
# 4. Plot PCA amb colors per cluster
grups <- c(rep("SA", n1), rep("F0", n2), rep("F4", n3))
plot(pca$x[,1], pca$x[,2], col = c("red","green","blue")[as.factor(grups)], pch=19)
